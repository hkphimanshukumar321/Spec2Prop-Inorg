        <mxCell id="87" value="&lt;b&gt;LightGBM-DART&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;Optuna HPO (50 trials, TPE sampler)&lt;/b&gt;&lt;br/&gt;• n_estimators: 300–2000&lt;br/&gt;• max_depth: 3–10&lt;br/&gt;• learning_rate: 0.01–0.3 (log)&lt;br/&gt;• subsample: 0.5–1.0&lt;br/&gt;• colsample_bytree: 0.3–1.0&lt;br/&gt;• num_leaves: 15–127&lt;br/&gt;• reg_alpha / reg_lambda: 1e-3–10 (log)&lt;br/&gt;• drop_rate (DART): 0.05–0.3&lt;br/&gt;• class_weight: balanced&lt;br/&gt;• objective: multiclass (K=9)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#880E4F;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=8;" vertex="1" parent="1">
