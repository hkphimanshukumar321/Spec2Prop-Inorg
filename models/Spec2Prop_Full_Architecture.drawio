          <mxGeometry x="390" y="2220" width="190" height="140" as="geometry" />
        </mxCell>
        <mxCell id="98" value="&lt;b&gt;Saved Deployment Artifacts&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• &lt;b&gt;pca.joblib&lt;/b&gt; — fitted PCA(32) on training set&lt;br/&gt;• &lt;b&gt;scaler.joblib&lt;/b&gt; — fitted StandardScaler on training features&lt;br/&gt;• &lt;b&gt;prototype_extractor.joblib&lt;/b&gt; — fitted class prototypes (train-only)&lt;br/&gt;• &lt;b&gt;lgbm_deployment.joblib&lt;/b&gt; — Optuna-tuned LightGBM-DART model&lt;br/&gt;• &lt;b&gt;encoder.json&lt;/b&gt; — label → integer mapping (9 families)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#9E9E9E;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="2400" width="560" height="80" as="geometry" />
        </mxCell>
        <mxCell id="99" value="HeterogeneousFeatureExtractor  (hybrid_models.py)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#546E7A;strokeWidth=3;dashed=1;dashPattern=8 4;arcSize=6;verticalAlign=top;fontFamily=Helvetica;fontSize=16;fontStyle=1;fontColor=#546E7A;labelBackgroundColor=#FFFFFF;spacingTop=5;" vertex="1" connectable="0" parent="1">
          <mxGeometry x="1020" y="320" width="360" height="260" as="geometry" />
        </mxCell>
        <mxCell id="100" value="&lt;b&gt;Hybrid Feature Pipeline&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Combines 3 heterogeneous feature sources:&lt;br/&gt;&lt;br/&gt;① &lt;b&gt;CNN Embedding&lt;/b&gt; (128-d)&lt;br/&gt;   • forward_features() from any trained encoder&lt;br/&gt;   • Batch inference (bs=64) with torch.no_grad()&lt;br/&gt;&lt;br/&gt;② &lt;b&gt;PCA Components&lt;/b&gt; (32-d)&lt;br/&gt;   • sklearn PCA.transform() on raw 2048-d&lt;br/&gt;&lt;br/&gt;③ &lt;b&gt;Domain Descriptors&lt;/b&gt; (126-d→163-d)&lt;br/&gt;   • extract_domain_features(n_peaks=10)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Total: ~286–350-d vector&lt;/b&gt;&lt;br/&gt;→ fed to GBDT/TabPFN classifier&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#546E7A;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1040" y="360" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="101" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#00695C;strokeWidth=2;fontFamily=Helvetica;fontSize=11;" edge="1" parent="1" source="30" target="100">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="102" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#00695C;strokeWidth=2;fontFamily=Helvetica;fontSize=11;" edge="1" parent="1" source="51" target="100">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="103" value="&lt;b&gt;Diagnostic Raman Band Windows&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;Window&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;b&gt;Index range&lt;/b&gt;&lt;br/&gt;silicate_main (Si-O bend) &amp;nbsp;&amp;nbsp; 200–280&lt;br/&gt;silicate_stretch (Si-O-Si) &amp;nbsp;&amp;nbsp; 830–900&lt;br/&gt;carbonate (CO₃ bend) &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; 560–620&lt;br/&gt;phosphate (P-O stretch) &amp;nbsp;&amp;nbsp;&amp;nbsp; 530–590&lt;br/&gt;oxide_low (M-O lattice) &amp;nbsp;&amp;nbsp;&amp;nbsp; 100–180&lt;br/&gt;ch_stretch (C-H organics) &amp;nbsp; 1780–1950&lt;br/&gt;oh_stretch (O-H hydrated) &amp;nbsp; 1950–2048&lt;br/&gt;&lt;br/&gt;&lt;i&gt;7 band means + ⁷C₂ = 21 pairwise ratios = 28 features&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#78909C;strokeWidth=2;fontFamily=Helvetica;fontSize=10;fontStyle=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="620" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="104" value="&lt;b&gt;Baseline CNN Encoders  (cnn1d.py)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;SimpleCNN1D&lt;/b&gt;&lt;br/&gt;  Conv1D(1→32,k=7) → BN → ReLU → Pool(4)&lt;br/&gt;  Conv1D(32→64,k=5) → BN → ReLU → Pool(4)&lt;br/&gt;  Conv1D(64→128,k=3) → BN → ReLU → Pool(4)&lt;br/&gt;  GAP → FC(128→128). embed_dim=128&lt;br/&gt;&lt;br/&gt;&lt;b&gt;LiteSpecNet&lt;/b&gt; (~15K params, edge-friendly)&lt;br/&gt;  Conv1D(1→16,k=11) → DepthwiseSep(16→32,k=7)&lt;br/&gt;  → DepthwiseSep(32→48,k=5) → GAP → FC(48→64)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;ResidualCNN1D&lt;/b&gt;&lt;br/&gt;  Conv→Pool→ResBlock(32)→Pool&lt;br/&gt;  Conv→Pool→ResBlock(64)→Pool&lt;br/&gt;  Conv→Pool→GAP→FC(128→128)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#78909C;strokeWidth=2;fontFamily=Helvetica;fontSize=10;fontStyle=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="840" width="360" height="210" as="geometry" />
        </mxCell>
        <mxCell id="105" value="&lt;b&gt;RamanPCAMLP  (cnn1d.py)&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Frozen PCA projection: Linear(2048→pca_dim)&lt;br/&gt;MLP: BN → Linear(pca_dim→512) → BN → ReLU → Drop&lt;br/&gt;     Linear(512→256) → BN → ReLU → Drop&lt;br/&gt;     Linear(256→128) → BN → ReLU → Drop&lt;br/&gt;Head: Linear(128→K)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#78909C;strokeWidth=2;fontFamily=Helvetica;fontSize=10;fontStyle=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="1070" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="106" value="&lt;b&gt;Fusion &amp;amp; Multimodal Models&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;&lt;b&gt;FusionSpec2PropNet&lt;/b&gt; (fusion_models.py)&lt;br/&gt;  Raman CNN + Descriptor MLP → Concat → Fusion FC&lt;br/&gt;  → Multi-task heads (classification + regression)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;DualBranchRamanXRDNet&lt;/b&gt; (multimodal_cnn.py)&lt;br/&gt;  Raman CNN + XRD CNN + Optional Descriptor MLP&lt;br/&gt;  → Concat → Fusion FC → FusionMultiTaskHead&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#78909C;strokeWidth=2;fontFamily=Helvetica;fontSize=10;fontStyle=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1020" y="1210" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="107" value="&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;Figure:&lt;/b&gt; Complete Spec2Prop-Edge architecture. Two flagship deep models (MultiScaleSpecNet with ASPP+CAS, RamanFormer1D v2 with SupCon) produce 128-d embeddings. For deployment, raw 2048-point spectra are transformed into a 222-d heterogeneous vector (163 domain + 32 PCA + 27 prototype features), scaled, and classified by an Optuna-tuned LightGBM-DART. The system outputs top-k inorganic family predictions with confidence scores for scientist verification.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Helvetica;fontSize=11;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="40" y="2510" width="1340" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>