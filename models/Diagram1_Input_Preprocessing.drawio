        <mxCell id="4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;strokeWidth=2;fontFamily=Helvetica;fontSize=12;fontStyle=1;arcSize=10;" value="&lt;b&gt;Raman Spectrometer Output&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;File format:&lt;/b&gt; CSV / TXT&lt;br/&gt;&lt;b&gt;X-axis:&lt;/b&gt; Raman shift (cm&lt;sup&gt;-1&lt;/sup&gt;)&lt;br/&gt;&lt;b&gt;Y-axis:&lt;/b&gt; Intensity (a.u.)&lt;br/&gt;&lt;b&gt;Physical meaning:&lt;/b&gt; Vibrational fingerprint&lt;br/&gt;of molecular bonds and crystal structure&lt;br/&gt;&lt;b&gt;Role:&lt;/b&gt; Primary input (v1 deployment)&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="300" x="60" y="130" as="geometry" />
