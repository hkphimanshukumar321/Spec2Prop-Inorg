        <mxCell id="8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1565C0;strokeWidth=2;dashed=0;arcSize=8;verticalAlign=top;fontFamily=Helvetica;fontSize=15;fontStyle=1;fontColor=#1565C0;labelBackgroundColor=#FFFFFF;spacingTop=5;container=0;" value="Runtime Spectral Preprocessing (executed at inference time, not cached)" vertex="1">
          <mxGeometry height="380" width="920" x="420" y="80" as="geometry" />
        </mxCell>
        <mxCell id="9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=10;" value="&lt;b&gt;1. Raw File Parsing&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Read CSV/TXT, detect delimiter,&#xa;extract (x, y) columns&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="200" x="440" y="130" as="geometry" />
        </mxCell>
        <mxCell id="10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=10;" value="&lt;b&gt;2. Invalid Row Removal&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Drop NaN, Inf, negative intensities,&#xa;non-numeric entries&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="200" x="650" y="130" as="geometry" />
        </mxCell>
        <mxCell id="11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=10;" value="&lt;b&gt;3. Axis Sorting &amp;amp;&#xa;    Duplicate Removal&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Sort by wavenumber/angle,&#xa;remove duplicate x-values&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="200" x="860" y="130" as="geometry" />
        </mxCell>
        <mxCell id="12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=10;" value="&lt;b&gt;4. Interpolation to&#xa;    Fixed Grid&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Cubic spline interpolation&#xa;to exactly 2048 equally-spaced points&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="200" x="1070" y="130" as="geometry" />
        </mxCell>
        <mxCell id="13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=10;" value="&lt;b&gt;5. Baseline Correction&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Asymmetric least-squares (ALS)&#xa;or polynomial baseline subtraction&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="200" x="440" y="285" as="geometry" />
        </mxCell>
        <mxCell id="14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=10;" value="&lt;b&gt;6. Savitzky-Golay&#xa;    Smoothing&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Polynomial smoothing filter&#xa;preserves peak shapes&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="200" x="650" y="285" as="geometry" />
        </mxCell>
        <mxCell id="15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontFamily=Helvetica;fontSize=11;fontStyle=1;arcSize=10;" value="&lt;b&gt;7. Min-Max&#xa;    Normalisation&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Scale intensities to [0, 1]&#xa;per-spectrum normalisation&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="200" x="860" y="285" as="geometry" />
        </mxCell>
