        <mxCell id="5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;strokeWidth=2;fontFamily=Helvetica;fontSize=12;fontStyle=1;arcSize=10;strokeDasharray=8 4;" value="&lt;b&gt;XRD Diffractometer Output&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;File format:&lt;/b&gt; CSV / TXT&lt;br/&gt;&lt;b&gt;X-axis:&lt;/b&gt; 2&amp;#x3b8; angle (degrees)&lt;br/&gt;&lt;b&gt;Y-axis:&lt;/b&gt; Intensity (counts)&lt;br/&gt;&lt;b&gt;Physical meaning:&lt;/b&gt; Structural fingerprint&lt;br/&gt;of crystallographic planes&lt;br/&gt;&lt;b&gt;Role:&lt;/b&gt; Optional / multimodal extension&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="300" x="60" y="280" as="geometry" />
